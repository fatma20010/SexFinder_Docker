# Copy to .env in this folder on your cloud VM (same directory as docker-compose.yml).
# Use absolute POSIX paths. Required so the backend can mount uploads/output into pipeline containers.
#
# Example VM layout: repo at /opt/SexFindR
# HOST_UPLOADS_PATH=/opt/SexFindR/web_interface/uploads
# HOST_OUTPUT_PATH=/opt/SexFindR/web_interface/output
# HOST_PROJECT_ROOT=/opt/SexFindR

HOST_UPLOADS_PATH=
HOST_OUTPUT_PATH=
HOST_PROJECT_ROOT=

# Optional: Block Storage bind for Step_* and output (copy docker-compose.override.example.yml
# to docker-compose.override.yml and set this to the host path prefix, e.g.
# SEXFINDR_VOLUME_ROOT=/mnt/volume_nyc1_1778011317813/sexfindr/web_interface
SEXFINDR_VOLUME_ROOT=
